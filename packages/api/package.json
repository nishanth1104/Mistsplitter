{
  "name": "@mistsplitter/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "start": "node --env-file=../../.env dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@mistsplitter/agents": "workspace:*",
    "@mistsplitter/audit": "workspace:*",
    "@mistsplitter/core": "workspace:*",
    "@mistsplitter/policy": "workspace:*",
    "@mistsplitter/workflow": "workspace:*",
    "dotenv": "^17.4.0",
    "fastify": "^4.28.0",
    "prom-client": "^15.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
