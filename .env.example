# ─── Database ────────────────────────────────────────────────────────────────
# Add ?connection_limit=10&pool_timeout=20 for high-concurrency prod deployments
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mistsplitter"

# ─── API Service ─────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info          # trace | debug | info | warn | error | fatal
RATE_LIMIT_MAX=100      # requests per minute per IP (global limit)

# ─── MCP Server ──────────────────────────────────────────────────────────────
MCP_PORT=3001

# ─── AI (OpenAI) ─────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-proj-your-key-here"

# ─── Auth ────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Use a random secret in production.
JWT_SECRET="dev-secret-change-in-production-min-32-chars"

# ─── Signal Thresholds (optional — defaults shown) ──────────────────────────
# Change without code deploy by setting env vars in your runtime config.
HIGH_AMOUNT_THRESHOLD=10000          # USD amount above which high_amount signal fires
RAPID_SUCCESSION_COUNT=3             # transactions within window that triggers rapid_succession
RAPID_SUCCESSION_HOURS=24            # rolling window in hours for rapid_succession
AMOUNT_DEVIATION_MULTIPLIER=2        # deviation ratio above which amount_deviation fires

# ─── PostgreSQL (docker-compose only) ────────────────────────────────────────
POSTGRES_PASSWORD=postgres
